{
  "name": "rooted-wisdom",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "watch:sass": "sass --watch sass:assets/css --style=expanded",
    "watch:sass:site": "sass --watch sass:_site/assets/css --style=expanded --no-source-map",
    "build:sass": "sass sass:assets/css --style=compressed",
    "watch:eleventy": "npx @11ty/eleventy --config=.eleventy.js --serve",
    "build:eleventy": "npx @11ty/eleventy --config=.eleventy.js",
    "start": "npm-run-all build:sass --parallel watch:eleventy watch:sass:site",
    "build": "npm-run-all build:*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "markdown-it": "^14.0.0",
    "markdown-it-attrs": "^4.3.1",
    "npm-run-all": "^4.1.5",
    "sass": "^1.87.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
